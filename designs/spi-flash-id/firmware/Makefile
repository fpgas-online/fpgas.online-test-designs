# Firmware Makefile for SPI Flash JEDEC ID test.
#
# This is compiled against the LiteX-generated headers and linker script.
# The gateware must be built first so that $(BUILD_DIR) contains the
# generated CSR headers, memory map, and linker regions.
#
# Usage (after gateware build):
#   make -C designs/spi-flash-id/firmware BUILD_DIR=../build/arty
#
# NOTE: This firmware is built separately from the gateware. Run the
# gateware build first, then build firmware against the generated output.

BUILD_DIR ?= ../build/arty

# Guard: variables.mak is generated by the LiteX build. If it does not
# exist the gateware has not been built yet.
VARIABLES_MAK := $(BUILD_DIR)/software/include/generated/variables.mak
ifeq ($(wildcard $(VARIABLES_MAK)),)
  $(error $(VARIABLES_MAK) not found — build the gateware first)
endif

include $(VARIABLES_MAK)
include $(SOC_DIRECTORY)/software/common.mak

# Use the LiteX-generated linker regions file.
LINKER_LD := $(BUILD_DIR)/software/include/generated/regions.ld

OBJECTS = main.o

all: firmware.bin

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

firmware.elf: $(OBJECTS)
	$(LD) $(LDFLAGS) -T $(LINKER_LD) -o $@ $^ -L$(BUILD_DIR)/software/libbase -lbase-nofloat -L$(BUILD_DIR)/software/libcompiler_rt -lcompiler_rt

firmware.bin: firmware.elf
	$(OBJCOPY) -O binary $< $@

clean:
	rm -f *.o *.elf *.bin

.PHONY: all clean
